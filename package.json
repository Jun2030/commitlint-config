{
  "name": "@2030/commitlint-config",
  "version": "3.0.1-beta.2",
  "description": "Shareable commitlint config for enforcing conventional commits",
  "keywords": [
    "commitlint",
    "commitlint-config"
  ],
  "homepage": "https://github.com/Jun2030/commitlint-config#readme",
  "repository": "https://github.com/Jun2030/commitlint-config",
  "license": "MIT",
  "author": "DaiJun<zijun2030@163.com>",
  "type": "module",
  "main": "index.js",
  "files": [
    "index.js"
  ],
  "scripts": {
    "test": "node --test",
    "release": "bumpp package.json packages/*/package.json --commit --push --tag --no-verify",
    "prepare": "husky"
  },
  "dependencies": {
    "@commitlint/config-conventional": "20.3.1"
  },
  "devDependencies": {
    "bumpp": "10.4.0",
    "husky": "9.1.7"
  },
  "peerDependencies": {
    "@commitlint/cli": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
